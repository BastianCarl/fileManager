@fileId = 02584d82-8ccd-4f95-bb96-c67d9a856769

###
# @name getStatus
GET {{rootURL}}/files/6931a24b-0485-4830-8dad-d4c40c2a9a19
Authentication: Bearer {{token}}
Accept: application/json